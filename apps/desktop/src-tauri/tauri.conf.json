{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSCIRIS Node",
  "version": "0.1.2",
  "identifier": "com.oscirislabs.node",
  "build": {
    "beforeDevCommand": "pnpm prepare:sidecar:debug && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OSCIRIS Node",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; frame-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": false,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Control a local OSCIRIS participant node",
    "longDescription": "Cross-platform desktop controller for provider-local OSCIRIS compute participation.",
    "externalBin": ["binaries/osciris-daemon"],
    "licenseFile": "../../../LICENSE",
    "resources": {
      "../../../LICENSE": "LICENSE",
      "../../../NOTICE": "NOTICE"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwRDkzNTRGMTBGQTk0Q0QKUldUTmxQb1FUelhad0VHcGlyZ2hJMDFlZldvV2RUcDR2NkRGQmt2dk0vT3JCTmRndVNvSGZjem4K",
      "endpoints": [
        "https://github.com/oscirisprotocol/core/releases/latest/download/latest.json"
      ]
    }
  }
}
