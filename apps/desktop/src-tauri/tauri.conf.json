{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OSCIRIS Node",
  "version": "0.1.1",
  "identifier": "com.oscirislabs.node",
  "build": {
    "beforeDevCommand": "pnpm prepare:sidecar:debug && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm prepare:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OSCIRIS Node",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; frame-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Control a local OSCIRIS participant node",
    "longDescription": "Cross-platform desktop controller for provider-local OSCIRIS compute participation.",
    "externalBin": ["binaries/osciris-daemon"],
    "licenseFile": "../../../LICENSE",
    "resources": {
      "../../../LICENSE": "LICENSE",
      "../../../NOTICE": "NOTICE"
    }
  }
}
